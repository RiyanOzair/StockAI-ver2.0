# StockAI - FREE LLM Configuration
# Copy this file to .env and add your free API keys

# =============================================
# GROQ (FREE - Recommended!)
# Get your free API key at: https://console.groq.com
# Supports: Llama 3.3 70B, Llama 3.1 8B, Mixtral 8x7B
# =============================================
GROQ_API_KEY=your_groq_api_key_here

# =============================================
# GOOGLE GEMINI (FREE tier available)
# Get your free API key at: https://aistudio.google.com
# Supports: Gemini 1.5 Flash, Gemini 2.0 Flash
# =============================================
GOOGLE_API_KEY=your_google_api_key_here

# =============================================
# OLLAMA (FREE - Local, no API key needed!)
# Install from: https://ollama.ai
# Then run: ollama pull llama3
# =============================================
OLLAMA_HOST=http://localhost:11434

# =============================================
# OpenAI (PAID - optional, for legacy support)
# =============================================
# OPENAI_API_KEY=your_openai_api_key_here
